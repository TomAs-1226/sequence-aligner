<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SequenceAlignerApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SequenceAlignerApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Controls -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <TextBlock Text="Tune the scoring" Style="{StaticResource SubtitleTextBlockStyle}" />

                <TextBox x:Name="Seq1Box" Header="Sequence 1" AcceptsReturn="True"
                         TextWrapping="Wrap" Height="80" FontFamily="Consolas" />
                <TextBox x:Name="Seq2Box" Header="Sequence 2" AcceptsReturn="True"
                         TextWrapping="Wrap" Height="80" FontFamily="Consolas" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Load file 1" Click="LoadFile1_Click" />
                    <Button Content="Load file 2" Click="LoadFile2_Click" />
                    <Button Content="Swap" Click="Swap_Click" />
                </StackPanel>

                <ComboBox x:Name="SampleBox" Header="Load a sample" HorizontalAlignment="Stretch"
                          SelectionChanged="Sample_Changed">
                    <ComboBoxItem Content="(choose a sample)" />
                    <ComboBoxItem Content="Toy DNA" />
                    <ComboBoxItem Content="HBB: human vs gorilla" />
                    <ComboBoxItem Content="HBB: human vs zebrafish" />
                    <ComboBoxItem Content="SARS spike (DNA)" />
                    <ComboBoxItem Content="SARS spike (protein)" />
                    <ComboBoxItem Content="SARS whole genomes (30 kb, banded)" />
                    <ComboBoxItem Content="Cytochrome c: human vs yeast" />
                </ComboBox>

                <ComboBox x:Name="TypeBox" Header="Sequence type" HorizontalAlignment="Stretch"
                          SelectionChanged="Params_Changed">
                    <ComboBoxItem Content="DNA" />
                    <ComboBoxItem Content="Protein" />
                </ComboBox>
                <ComboBox x:Name="ModeBox" Header="Mode" HorizontalAlignment="Stretch"
                          SelectionChanged="Params_Changed">
                    <ComboBoxItem Content="Global (whole sequences)" />
                    <ComboBoxItem Content="Local (best stretch)" />
                    <ComboBoxItem Content="Semi-global (free end gaps)" />
                </ComboBox>
                <ComboBox x:Name="MatrixBox" Header="Protein scoring matrix" HorizontalAlignment="Stretch"
                          SelectionChanged="Params_Changed">
                    <ComboBoxItem Content="BLOSUM62" />
                    <ComboBoxItem Content="PAM250" />
                </ComboBox>
                <ComboBox x:Name="GapModelBox" Header="Gap model" HorizontalAlignment="Stretch"
                          SelectionChanged="Params_Changed">
                    <ComboBoxItem Content="Linear (one flat penalty)" />
                    <ComboBoxItem Content="Affine (open + extend)" />
                </ComboBox>

                <TextBlock x:Name="MatchLabel" Text="Match reward: 2" />
                <Slider x:Name="MatchSlider" Minimum="0" Maximum="10" Value="2"
                        StepFrequency="0.5" ValueChanged="Slider_Changed" />
                <TextBlock x:Name="MismatchLabel" Text="Mismatch penalty: 2" />
                <Slider x:Name="MismatchSlider" Minimum="0" Maximum="10" Value="2"
                        StepFrequency="0.5" ValueChanged="Slider_Changed" />
                <TextBlock x:Name="GapLabel" Text="Gap penalty: 3" />
                <Slider x:Name="GapSlider" Minimum="0" Maximum="20" Value="3"
                        StepFrequency="0.5" ValueChanged="Slider_Changed" />

                <StackPanel x:Name="AffinePanel" Spacing="6" Visibility="Collapsed">
                    <TextBlock x:Name="OpenLabel" Text="Gap open: 8" />
                    <Slider x:Name="OpenSlider" Minimum="0" Maximum="20" Value="8"
                            StepFrequency="0.5" ValueChanged="Slider_Changed" />
                    <TextBlock x:Name="ExtendLabel" Text="Gap extend: 1" />
                    <Slider x:Name="ExtendSlider" Minimum="0" Maximum="10" Value="1"
                            StepFrequency="0.5" ValueChanged="Slider_Changed" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Align" Style="{StaticResource AccentButtonStyle}" Click="Align_Click" />
                    <Button Content="Translate DNA to protein" Click="Translate_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Reverse complement seq 2" Click="RevComp_Click" />
                    <Button Content="Show scoring matrix" Click="ShowMatrix_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Results -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock Text="Result" Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,10" MinWidth="120">
                        <StackPanel>
                            <TextBlock Text="Score" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="ScoreText" Text="-" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,10" MinWidth="120">
                        <StackPanel>
                            <TextBlock Text="Percent identity" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="IdentityText" Text="-" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,10" MinWidth="120">
                        <StackPanel>
                            <TextBlock Text="Gaps" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="GapsText" Text="-" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="StatsText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <TextBlock Text="Legend:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="match" Foreground="#2E7D46" />
                            <TextBlock Text="mismatch" Foreground="#C43D2E" />
                            <TextBlock Text="gap" Foreground="#8A8A8A" />
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <RichTextBlock x:Name="AlignmentView" FontFamily="Consolas" FontSize="14" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Copy alignment" Click="Copy_Click" />
                    <Button Content="Save alignment..." Click="Save_Click" />
                </StackPanel>

                <Expander Header="Dot plot (shared short pieces)" HorizontalAlignment="Stretch">
                    <Image x:Name="DotImage" Width="340" Height="340" Stretch="None" HorizontalAlignment="Left" />
                </Expander>

                <Expander Header="3D viewer (color a structure by the current alignment)" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Show current alignment in 3D" Click="Load3D_Click" />
                            <ComboBox x:Name="StructureSourceBox" Width="190" SelectedIndex="0">
                                <ComboBoxItem Content="Predict from sequence" />
                                <ComboBoxItem Content="From PDB ID" />
                            </ComboBox>
                            <TextBox x:Name="PdbBox" Text="6VXX" Width="90" PlaceholderText="PDB ID" VerticalAlignment="Center" />
                            <TextBlock x:Name="ThreeDStatus" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="Predict from sequence folds sequence 2 with ESMFold, so any protein alignment (up to 400 residues) gets a 3D view, colored red where the two sequences differ. From PDB ID loads a known structure instead (for example 6VXX for the SARS spike, which is too long to predict). Needs an internet connection."
                                   TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ComboBox x:Name="RepBox" Width="130" SelectedIndex="0" SelectionChanged="Rep_Changed">
                                <ComboBoxItem Content="Cartoon" />
                                <ComboBoxItem Content="Sticks" />
                                <ComboBoxItem Content="Spheres" />
                            </ComboBox>
                            <CheckBox x:Name="SpinCheck" Content="Spin" Checked="Spin_Toggled" Unchecked="Spin_Toggled" VerticalAlignment="Center" />
                            <Button Content="Save structure (.pdb)" Click="SaveStructure_Click" />
                        </StackPanel>
                        <WebView2 x:Name="Viewer3D" Height="480" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
